{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/briefing?tipo=matutino",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/briefing?tipo=mediodia",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/briefing?tipo=cierre",
      "schedule": "0 22 * * *"
    }
  ],
  "functions": {
    "api/briefing.js": {
      "maxDuration": 30
    },
    "api/telegram.js": {
      "maxDuration": 30
    }
  }
}
