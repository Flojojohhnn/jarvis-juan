# ============================================
# ANTHROPIC
# ============================================
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ============================================
# TELEGRAM
# ============================================
# Token que te da @BotFather cuando creás el bot
TELEGRAM_BOT_TOKEN=123456789:ABCdef...

# Tu user ID de Telegram. Obtenelo escribiendo a @userinfobot
TELEGRAM_ALLOWED_USER_ID=123456789

# Secret que vos elegís - 32 caracteres random. Telegram lo manda en cada webhook
# Generar con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=...

# ============================================
# GOOGLE CALENDAR (service account)
# ============================================
# Email del service account (viene del JSON que descargás de Google Cloud)
# Formato: nombre-del-sa@proyecto.iam.gserviceaccount.com
GOOGLE_CLIENT_EMAIL=jarvis-juan@proyecto-xxx.iam.gserviceaccount.com

# Private key del JSON del service account.
# IMPORTANTE: pegalo TAL CUAL del JSON, con los \n literales
# Ej: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ID del calendar que querés que lea. Normalmente es tu email de Google.
# Tenés que COMPARTIR este calendar con el email del service account
# (Configuración del calendar > Compartir con usuarios específicos)
GOOGLE_CALENDAR_ID=juan@gmail.com

# ============================================
# VERCEL CRON
# ============================================
# Generar con: openssl rand -hex 32
CRON_SECRET=...

# ============================================
# UPSTASH REDIS (ya lo tenés del proyecto Óvalo Closer)
# ============================================
# Si usás la misma instancia que Óvalo Closer:
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...

# O las nuevas variables de Upstash (si creás una nueva instancia):
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
